{
    "manifest_version": 3,
    "name": "Save Image As PNG/JPG",
    "version": "1.0",
    "description": "Right-click any image to save it instantly as a PNG or JPG.",
    "background": {
        "service_worker": "background.js"
    },
    "permissions": [
        "contextMenus",
        "downloads"
    ],
    "host_permissions": [
        "<all_urls>"
    ]
}